<html>
    <center>
        <form action="/product/final_picture_edit" method="post" enctype="multipart/form-data">
        <input type="hidden" name="productid" value="<%= data.id %>"/>
        <h2><%= data.name %></h2>
        <img src="/images/<%= data.picture %>" style="width:400px;height:400px;"/><br><br><br>
        <input type="file" name="picture"/><br><br><br>
        <input type="submit" value="Edit Picture"/>
        </form>
    </center>
</html>