<!DOCTYPE html>
<html>
<head>
    <title>Display All Products</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>

<div class="container mt-5">

    <h2 class="text-center mb-4">Display All Products</h2>

    <table class="table table-bordered table-hover text-center">
        <thead class="table-dark">
            <tr>
                <th>Product ID</th>
                <th>Category ID</th>
                <th>Subcategory ID</th>
                <th>Product Name</th>
                <th>Product Rate</th>
                <th>Product Offer</th>
                <th>Stock</th>
                <th>Weight</th>
            </tr>
        </thead>

        <tbody>
            <tr>
                <td>1</td>
                <td>1</td>
                <td>1</td>
                <td>Barbie Doll</td>
                <td>999</td>
                <td>10%</td>
                <td>50</td>
                <td>300g</td>
            </tr>

            <tr>
                <td>2</td>
                <td>1</td>
                <td>2</td>
                <td>Doll House</td>
                <td>2499</td>
                <td>15%</td>
                <td>20</td>
                <td>1.5kg</td>
            </tr>

            <tr>
                <td>3</td>
                <td>1</td>
                <td>3</td>
                <td>Teddy Bear</td>
                <td>799</td>
                <td>5%</td>
                <td>35</td>
                <td>500g</td>
            </tr>

            <tr>
                <td>4</td>
                <td>1</td>
                <td>4</td>
                <td>Remote Control Car</td>
                <td>1599</td>
                <td>20%</td>
                <td>25</td>
                <td>700g</td>
            </tr>
        </tbody>

    </table>

</div>

</body>
</html>