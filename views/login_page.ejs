    </head>
    <form action="/product/chk_login" method="post">
    <div class = "maincontainer">
<div class="box form-card3">
    <div class="container p-0">
    <div class="row">
        <div class="col-md-12">
            <div style="display:flex;flex-direction:center;width:100%; justify-content:center;padding:5px;border-radius:20px;align-items:center; background:black;">
         <span><img src="/images/bag.png" style="width : 50px; height : 50px;"></span>
        <span class="textstyle">Welcome to Gifteria</span>
        </div> 
    </div>
     </div>
    </div>
    <div class="row">
        <div class="col-md-12 tagline" style="margin-top:20px;">
            <div style="display:flex;flex-direction:center;width:100%; justify-content:center;padding:5px;border-radius:20px;align-items:center;">
        <span><img src="/images/bow (1).png" style="width : 50px; height : 50px;"></span>
                <span class="textstyle2">Find the perfect gift for every special moment...........</span>
    </div>
    </div>
    </div>
    <% if (typeof message !== 'undefined' && message) { %>
      <div class="alert alert-danger" style="margin-top: 15px;">
        <%= message %>
      </div>
    <% } %>
  <div class="mb-3">
    <label for="exampleInputEmail1" class="form-label textstyle3">Email address</label>
    <input type="email" class="form-control" id="emailid" name="emailid" aria-describedby="emailHelp" placeholder="EmailID" >
    <div id="emailHelp" class="form-text">We'll never share your email with anyone else.</div>
  </div>
  <div class="mb-3">
    <label for="exampleInputPassword1" class="form-label textstyle3">Password</label>
    <input type="password" class="form-control" id="pwd" name="pwd" placeholder="Password">
  </div>
  <div class="mb-3 form-check">
    <input type="checkbox" class="form-check-input" id="exampleCheck1">
    <label class="form-check-label textstyle3" for="exampleCheck1">Check me out</label>
  </div>
<button type="submit" class="btn btn-login textstyle3" style="background-color: black;">
    🎁 Login
</button>
</form>
